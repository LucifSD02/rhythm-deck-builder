; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RhythmDeckBuilder"
run/main_scene="uid://bffdn0hyembvw"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

driver/output_latency=8

[autoload]

RhythmClock="*uid://buco80x2gc4aq"
Utilities="*uid://bddwp7mctai3t"

[debug]

gdscript/warnings/unused_signal=0
gdscript/warnings/untyped_declaration=2

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="RhythmDeckBuilder"

[editor_plugins]

enabled=PackedStringArray("res://addons/GDQuest_GDScript_formatter/plugin.cfg", "res://addons/at-icons/plugin.cfg", "res://addons/kanban_tasks/plugin.cfg", "res://addons/yard/plugin.cfg")

